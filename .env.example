APP_ENV=development
DATABASE_URL=sqlite:///./data/job_outreach.db
APP_HOST=127.0.0.1
APP_PORT=8000

# Separate credentials for this project. Do not reuse another application's keys.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_DAILY_REQUEST_LIMIT=25

BRAVE_API_KEY=
BRAVE_DAILY_QUERY_LIMIT=30
TARGET_JOB_QUERIES=junior data engineer|junior software developer|data analyst
TARGET_LOCATION=Canada
RESEARCH_DEPARTMENT=

# Download a Desktop OAuth client from Google Cloud and store it outside Git.
GMAIL_CREDENTIALS_FILE=./secrets/gmail_credentials.json
GMAIL_TOKEN_FILE=./secrets/gmail_token.json
GMAIL_QUERY=newer_than:180d (from:jobalerts-noreply@linkedin.com OR subject:"job alert")

USER_PROFILE_FILE=./data/profile.md
